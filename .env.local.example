# =====================================================================
# Dubai Villa & Townhouse Intelligence Engine — environment
# Copy to .env.local and fill in. The app runs in a degraded "preview"
# mode (no auth, empty catalogue) until Supabase is configured.
# =====================================================================

# --- Supabase (Postgres + Auth + Storage) ---------------------------
# From your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never expose to the browser. Used for trusted admin/seed ops.
SUPABASE_SERVICE_ROLE_KEY=

# Restrict sign-in to the single owner (optional but recommended).
ADMIN_EMAIL=

# --- Google Maps (custom-styled map, Milestone 1) -------------------
# Maps JavaScript API key + a vector Map ID with your dark/editorial style.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=

# --- Anthropic (on-demand generation, Milestones 5 & 7) -------------
ANTHROPIC_API_KEY=
# Optional — override the generation model (defaults to a current Claude model).
ANTHROPIC_MODEL=
